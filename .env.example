# ── Server ──────────────────────────────────────────────
# Your public URL (use ngrok for local dev: https://xxxx.ngrok.io)
SERVER_URL=https://YOUR_NGROK_URL_HERE
PORT=3000

# ── Twilio ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX   # Your Twilio number

# The German number to bridge to by default (can be overridden per call)
DEFAULT_TARGET_NUMBER=+49XXXXXXXXXX

# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── ElevenLabs ───────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Optional: override voice IDs per language (ElevenLabs voice IDs)
# ELEVENLABS_VOICE_DE=pNInz6obpgDQGcFmaJgB
# ELEVENLABS_VOICE_EN=EXAVITQu4vr4xnSDxMaL

# ── Languages ────────────────────────────────────────────
CALLER_LANG=en    # Language the caller speaks
TARGET_LANG=de    # Language the German party speaks
